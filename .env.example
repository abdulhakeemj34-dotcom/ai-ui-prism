# Hugging Face (server-side only — never expose to frontend)
HF_API_KEY=PASTE_HUGGINGFACE_API_KEY_HERE
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_PREMIUM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
